          {
            "fungicide": "Metalaxyl + Mancozeb (Ridomil MZ)",
            "dose": "600 g per acre",
            "method": "Foliar spray, repeat every 7-10 days",
            "waiting_period_days": 14
          },
          {
            "fungicide": "Cymoxanil + Mancozeb (Curzate M8)",
            "dose": "600 g per acre",
            "method": "Foliar spray",
            "waiting_period_days": 7
          },
          {
            "fungicide": "Chlorothalonil 75 WP",
            "dose": "400 g per acre",

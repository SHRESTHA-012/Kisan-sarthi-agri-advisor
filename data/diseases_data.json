      "management": {
        "cultural": [
          "Grow resistant hybrids",
          "Crop rotation",
          "Destroy infected debris"
        ],
        "chemical": [
          {
            "fungicide": "Mancozeb 75 WP",
            "dose": "600 g per acre",
            "method": "Foliar spray",
            "waiting_period_days": 7
          },
          {
            "fungicide": "Propiconazole 25 EC",
            "dose": "200 ml per acre",
            "method": "Foliar spray",
            "waiting_period_days": 21
          }
        ]
      }
    },
    {
      "id": "D006",
      "name_en": "Lentil Wilt",
      "name_hi": "मसूर का उकठा रोग",
      "type": "fungal",
      "pathogen": "Fusarium oxysporum f. sp. lentis",
      "affects_crops": ["C004"],
      "identification": {
        "symptoms": "Sudden wilting and yellowing of plants, brown discoloration of vascular tissue inside stem",
        "affected_parts": ["roots", "stem", "whole plant"],
        "color": "Brown vascular discoloration",
        "season": "December – February"
      },
      "management": {
        "cultural": [
          "Use resistant varieties (PL-8)",
          "Crop rotation with cereals",
          "Seed treatment before sowing"
        ],
        "chemical": [
          {
            "fungicide": "Carbendazim 50 WP",
            "dose": "2 g per kg seed",
            "method": "Seed treatment"
          },
          {
            "fungicide": "Trichoderma viride",
            "dose": "4 g per kg seed",
            "method": "Seed biopriming"
          }
        ]
      }
    },
    {
      "id": "D007",
      "name_en": "Mustard White Rust",
      "name_hi": "सरसों का सफेद रतुआ",
      "type": "fungal",
      "pathogen": "Albugo candida",
      "affects_crops": ["C005"],
      "identification": {
        "symptoms": "White blister-like pustules on lower leaf surface; distorted stems and flower parts (staghead)",
        "affected_parts": ["leaves (lower surface)", "stems", "flowers"],
        "color": "White chalky pustules",
        "season": "December – February",
        "favourable_conditions": "Cool temperature 10-18°C, high humidity"
      },
      "management": {
        "cultural": [
          "Use resistant varieties (Pusa Tarak, Pusa Mahak)",
          "Early sowing (before October 15)",
          "Avoid overhead irrigation"
        ],
        "chemical": [
          {
            "fungicide": "Metalaxyl + Mancozeb (Ridomil Gold)",
            "dose": "400 g per acre",
            "method": "Foliar spray",
            "waiting_period_days": 14
          },
          {
            "fungicide": "Mancozeb 75 WP",
            "dose": "600 g per acre",
            "method": "Foliar spray",
            "waiting_period_days": 7
          }
        ]
      }
    },
    {
      "id": "D008",
      "name_en": "Sugarcane Red Rot",
      "name_hi": "गन्ने का लाल सड़न रोग",
      "type": "fungal",
      "pathogen": "Colletotrichum falcatum",
      "affects_crops": ["C006"],
      "identification": {
        "symptoms": "Wilting of top leaves, red discoloration inside stalk with white patches, sour smell from stalk",
        "affected_parts": ["stalk internodes"],
        "color": "Red with white patches inside stalk",
        "season": "July – September",
        "favourable_conditions": "Waterlogging, high temperature, stem borer wounds"
      },
      "economic_importance": "Most destructive sugarcane disease in Bihar",
      "management": {
        "cultural": [
          "Use resistant varieties (CoSe-01434)",
          "Treat setts with fungicide before planting",
          "Remove and destroy infected clumps",
          "Avoid waterlogging"
        ],
        "chemical": [
          {
            "fungicide": "Carbendazim 50 WP",
            "dose": "Sett treatment: 1g/L water, soak for 15 min",
            "method": "Sett dip treatment before planting"
          }
        ]
      }
    },
    {
      "id": "D009",
      "name_en": "Potato Late Blight",
      "name_hi": "आलू का पछेती अंगमारी",

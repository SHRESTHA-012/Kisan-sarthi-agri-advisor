  "diseases": [
    {
      "id": "D001",
      "name_en": "Rice Blast",
      "name_hi": "धान का झुलसा रोग",
      "type": "fungal",
      "pathogen": "Magnaporthe oryzae",
      "affects_crops": ["C001"],
      "identification": {
        "symptoms": "Diamond-shaped grey lesions with brown border on leaves; neck rot at panicle base causing white ears",
        "affected_parts": ["leaves", "neck", "panicle"],
        "color": "Grey center, brown border, yellow halo",
        "season": "July – September",
        "favourable_conditions": "High humidity >90%, temperature 24-28°C, excess nitrogen"
      },
      "economic_importance": "Can cause 50-80% yield loss in severe cases",
      "management": {
        "cultural": [
          "Use resistant varieties (Rajendra Sweta, IR-64)",
          "Avoid excess nitrogen fertilizer",
          "Drain field periodically",
          "Destroy infected crop debris"
        ],
        "biological": [
          "Trichoderma viride seed treatment (4g/kg seed)",
          "Pseudomonas fluorescens spray (2.5 kg/acre)"
        ],
        "chemical": [
          {
            "fungicide": "Tricyclazole 75 WP",
            "dose": "120 g per acre",
            "method": "Foliar spray",
            "timing": "At first symptom appearance",
            "waiting_period_days": 7
          },
          {
            "fungicide": "Isoprothiolane 40 EC",
            "dose": "300 ml per acre",
            "method": "Foliar spray",
            "timing": "Preventive at boot leaf stage",
            "waiting_period_days": 14
          },
          {
            "fungicide": "Carbendazim 50 WP",
            "dose": "200 g per acre",
            "method": "Foliar spray",
            "waiting_period_days": 7
          }
        ]
      }
    },
    {
      "id": "D002",
      "name_en": "Bacterial Leaf Blight (BLB)",
      "name_hi": "जीवाणु पत्ती झुलसा",
      "type": "bacterial",
      "pathogen": "Xanthomonas oryzae pv. oryzae",
      "affects_crops": ["C001"],
      "identification": {
        "symptoms": "Water-soaked to yellowish stripe on leaf margin that turns straw-yellow; milky or opaque bacterial ooze from cut ends",
        "affected_parts": ["leaves", "leaf margins"],
        "color": "Yellow to straw color from margins",
        "season": "August – October",
        "favourable_conditions": "Flood, storm damage, high nitrogen, high humidity"
      },
      "management": {
        "cultural": [
          "Use certified disease-free seeds",
          "Avoid flood irrigation after disease onset",
          "Remove weed hosts",
          "Balanced potassium fertilization"
        ],
        "chemical": [
          {
            "fungicide": "Copper oxychloride 50 WP",
            "dose": "500 g per acre",
            "method": "Foliar spray",
            "waiting_period_days": 7
          },
          {
            "fungicide": "Streptomycin sulphate + Tetracycline (Plantomycin)",
            "dose": "100 g per acre",
            "method": "Foliar spray",
            "waiting_period_days": 7
          }
        ]
      }
    },
    {
      "id": "D003",
      "name_en": "Wheat Rust (Yellow/Brown)",
      "name_hi": "गेहूं का रतुआ",
      "type": "fungal",
      "pathogen": "Puccinia striiformis (Yellow) / Puccinia recondita (Brown)",
      "affects_crops": ["C002"],
      "identification": {
        "symptoms": "Yellow/orange powdery pustules arranged in stripes on leaves (yellow rust); scattered brown pustules (brown rust)",
        "affected_parts": ["leaves", "stem", "glumes"],
        "color": "Yellow-orange or brick-red powdery masses",
        "season": "January – March",
        "favourable_conditions": "Cool temperature 10-15°C, high humidity, dew"
      },
      "economic_importance": "Can cause 20-70% yield loss",
      "management": {
        "cultural": [
          "Grow resistant varieties (HD-2967, K-307)",
          "Timely sowing",
          "Avoid dense planting"
        ],
        "chemical": [
          {
            "fungicide": "Propiconazole 25 EC",
            "dose": "200 ml per acre",
            "method": "Foliar spray",
            "waiting_period_days": 21
          },
          {
            "fungicide": "Mancozeb 75 WP",
            "dose": "600 g per acre",
            "method": "Foliar spray",
            "waiting_period_days": 7
          }
        ]
      }
    },
    {
      "id": "D004",
      "name_en": "Wheat Loose Smut",
      "name_hi": "गेहूं का खुला कंड",
      "type": "fungal",
      "pathogen": "Ustilago segetum tritici",
      "affects_crops": ["C002"],
      "identification": {
        "symptoms": "Entire ear replaced by black powdery mass of spores, enclosed in thin membrane that ruptures at heading",
        "affected_parts": ["ear", "grains"],
        "color": "Black sooty mass",
        "season": "February – March (at heading)"
      },
      "management": {
        "cultural": [
          "Use certified seeds",
          "Hot water seed treatment (52°C for 10 min)"
        ],
        "chemical": [
          {
            "fungicide": "Carboxin 75 WP (Vitavax)",
            "dose": "2.5 g per kg seed",
            "method": "Seed treatment",
            "waiting_period_days": 0
          },
          {
            "fungicide": "Tebuconazole 2 DS",
            "dose": "1 g per kg seed",
            "method": "Seed treatment"
          }
        ]
      }
    },
